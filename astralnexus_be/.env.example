# Server Configuration
PORT=3001
HOST=localhost
NODE_ENV=development

# Google OAuth2.0 - REPLACE WITH YOUR ACTUAL CREDENTIALS FROM GOOGLE CONSOLE
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:3001/auth/google/callback

# Discord OAuth2.0 - REPLACE WITH YOUR ACTUAL CREDENTIALS FROM DISCORD DEVELOPER PORTAL
DISCORD_CLIENT_ID=your_discord_client_id_here
DISCORD_CLIENT_SECRET=your_discord_client_secret_here
DISCORD_REDIRECT_URI=http://localhost:3001/auth/discord/callback

FRONTEND_SUCCESS_REDIRECT=http://blog.localtest.me:3000
FRONTEND_ERROR_REDIRECT=http://localtest.me:3000/login?error=oauth_failed

# Session Configuration - GENERATE RANDOM STRINGS FOR PRODUCTION
JWT_SECRET=dev_jwt_secret_change_in_production_make_it_very_long_and_random
SESSION_SECRET=dev_session_secret_also_change_in_production_make_it_random

# CORS Configuration - Frontend URLs
CORS_ORIGIN=http://localtest.me:3000, http://blog.localtest.me:3000, http://admin.localtest.me:3000

# Database Configuration (for future use)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=astralnexus_db
DB_USER=admin
DB_PASSWORD=admin

# API Configuration
API_VERSION=1.0.0
