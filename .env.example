# Application Environment
NODE_ENV=development
PORT=3001

# Frontend Configuration
VITE_API_BASE_URL=http://localhost:3001

# Database Configuration
DATABASE_URL=postgresql://postgres:password@astralnexus_db:5432/astralnexus
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin
POSTGRES_DB=astralnexus

# OAuth Configuration - Google
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:3001/auth/google/callback

# OAuth Configuration - Discord
DISCORD_CLIENT_ID=your_discord_client_id_here
DISCORD_CLIENT_SECRET=your_secret_client_secret_here
DISCORD_REDIRECT_URI=http://localhost:3001/auth/discord/callback

FRONTEND_SUCCESS_REDIRECT=http://<sub-domain>.<domain>:3000
FRONTEND_ERROR_REDIRECT=http://<domain>/login?error=oauth_failed

# Session Configuration
SESSION_SECRET=your_super_secret_session_key_here_at_least_32_characters_long_development
SESSION_DOMAIN=.localtest.me
SESSION_SECURE=false
SESSION_SAME_SITE=lax
SESSION_HTTP_ONLY=true

# CORS Configuration
CORS_ORIGIN=http://localhost:3000,http://localtest.me:3000,http://blog.localtest.me:3000,http://admin.localtest.me:3000

# PostgreSQL Configuration for Docker
POSTGRES_LOG_STATEMENT=all
POSTGRES_INITDB_ARGS=--encoding=UTF-8 --lc-collate=C --lc-ctype=C

# Docker Network
COMPOSE_PROJECT_NAME=astral-nexus-dev
