# ------------------------------------------
# Supabase Configuration
# ------------------------------------------
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT_ID/settings/api
VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ------------------------------------------
# Application URLs
# ------------------------------------------
# Development URLs (localhost)
VITE_API_URL=http://localhost:3001
VITE_APP_URL=http://localhost:3000
VITE_BLOG_URL=http://localhost:3000/blog
VITE_ADMIN_URL=http://localhost:3000/admin

# Production URLs (uncomment and modify for production)
# VITE_API_URL=https://api.astralnexus.com
# VITE_APP_URL=https://astralnexus.com
# VITE_BLOG_URL=https://astralnexus.com/blog
# VITE_ADMIN_URL=https://astralnexus.com/admin

