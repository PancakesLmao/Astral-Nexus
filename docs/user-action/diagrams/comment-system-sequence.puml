      "picture": "user-avatar"
    },
    "likes_count": 0,
    "is_liked": false,
    "created_at": "2025-08-04T10:35:00Z"
  },
  "message": "Comment created successfully"
}
```
end note

API --> PS: 26. New comment data

== Phase 5: Real-time UI Updates ==
PS -> PS: 27. Add comment to postComments array (prepend)
PS -> PS: 28. Update post.comments_count
note right
**State Management:**
```typescript
// Add new comment to beginning of array
postComments.value.unshift(newComment);

// Update post count optimistically
const post = posts.value.find(p => p.id === postId);
if (post) {
  post.comments_count = (post.comments_count || 0) + 1;
}
```
**Benefits:**
- Instant UI feedback
- Consistent state across components
- Real-time count updates
end note

PS --> FE: 29. Update comments display
FE -> FE: 30. Clear comment form & reset state
FE -> U: 31. Show new comment instantly with success feedback

== Phase 6: Comment Like/Unlike Interaction ==
U -> FE: 32. Click like button on specific comment
note right: User toggles like on individual comment

FE -> FE: 33. Optimistic update (toggle comment like)
note right
**Optimistic Update Logic:**
```typescript
const optimisticLikeComment = (commentId: string) => {
  const comment = postComments.value.find(c => c.id === commentId);
  if (comment) {
    comment.is_liked = !comment.is_liked;
    comment.likes_count += comment.is_liked ? 1 : -1;
  }
};
```
**UX Benefits:**
- Instant visual feedback
- No waiting for server response
- Rollback capability on error
end note

FE -> PS: 34. likeComment(commentId)
PS -> API: 35. toggleCommentLike(commentId)
API -> BE: 36. POST /api/comments/:id/like
note right
**API Request Details:**
- URL: /api/comments/{commentId}/like
- Method: POST
- Headers: Authorization Bearer token
- Body: Empty (toggle action)
end note

== Phase 7: Comment Like Database Processing ==
BE -> BE: 37. Validate session & comment ownership
note right
**Security Validation:**
```typescript
const validation = {
  user: await authenticateUser(request),
  commentId: validateUUID(params.id),
  commentExists: await verifyCommentExists(commentId)
};
```
end note

BE -> DB: 38. Check existing comment like status
note right
**Like Status Query:**
```sql
SELECT EXISTS(
  SELECT 1 FROM comment_likes 
  WHERE comment_id = $1 AND user_id = $2
) as is_liked;
```
end note

DB --> BE: 39. Current like status

alt User hasn't liked comment yet
    BE -> DB: 40a. INSERT INTO comment_likes
    note right
    **Insert Comment Like:**
    ```sql
    INSERT INTO comment_likes (comment_id, user_id, created_at)
    VALUES ($1, $2, CURRENT_TIMESTAMP);
    ```
    **Database Trigger:**
    - Automatically increments comments.likes_count
    end note
    
    DB -> DB: 41a. Trigger updates comments.likes_count (+1)
    BE -> DB: 42a. SELECT updated comment with new count
    DB --> BE: 43a. Comment with increased like count
    
else User has already liked comment
    BE -> DB: 40b. DELETE FROM comment_likes
    note right
    **Remove Comment Like:**
    ```sql
    DELETE FROM comment_likes 
    WHERE comment_id = $1 AND user_id = $2;
    ```
    **Database Trigger:**
    - Automatically decrements comments.likes_count
    end note
    
    DB -> DB: 41b. Trigger updates comments.likes_count (-1)
    BE -> DB: 42b. SELECT updated comment with new count
    DB --> BE: 43b. Comment with decreased like count
end

BE --> API: 44. Updated comment response
note right
**API Response:**
```json
{
  "success": true,
  "data": {
    "id": "comment-uuid",
    "likes_count": 6,
    "is_liked": true
  },
  "message": "Comment like toggled"
}
```
end note

API --> PS: 45. Comment with new like status
PS -> PS: 46. Update specific comment in postComments array
PS --> FE: 47. Sync comment like state in UI
FE -> U: 48. Show final like state with animation

== Phase 8: Error Handling & Recovery ==
alt Network or Server Error
